# docker-log-alerter configuration

# Required: Discord webhook URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK

# Optional: Only watch specific containers (comma-separated)
# WATCH_CONTAINERS=flask_august,cron_speedtest

# Optional: Only watch containers with specific labels
# WATCH_LABELS=com.example.monitor=true

# Optional: Log levels to alert on (default: error,fatal,critical)
# LOG_LEVELS=error,fatal,critical

# Optional: How long to suppress duplicate errors in seconds (default: 3600)
# CACHE_TTL_SECONDS=3600

# Optional: Max errors to cache (default: 1000)
# CACHE_MAX_SIZE=1000

# Optional: Debug mode - samples first N logs from each container to verify connectivity
# DEBUG=true
# DEBUG_SAMPLE_COUNT=3
